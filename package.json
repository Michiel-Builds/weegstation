{
    "name":  "bulters-newton-app",
    "version":  "1.0.7",
    "type":  "module",
    "description":  "NewTon+ Metaalrecycling Bulters - voorraad- en weegsysteem voor metaalhandel",
    "author":  "Michiel Bulters",
    "main":  "electron.cjs",
    "scripts":  {
                    "dev":  "vite",
                    "build":  "vite build",
                    "preview":  "vite preview",
                    "electron":  "electron .",
                    "electron:dev":  "vite \u0026 electron .",
                    "dist":  "vite build \u0026\u0026 electron-builder"
                },
    "dependencies":  {
                         "electron-log":  "^5.4.4",
                         "electron-updater":  "^6.8.3",
                         "react":  "^18.0.0",
                         "react-dom":  "^18.0.0"
                     },
    "devDependencies":  {
                            "@vitejs/plugin-react":  "^4.7.0",
                            "electron":  "^42.3.3",
                            "electron-builder":  "^26.8.1",
                            "png-to-ico":  "^3.0.1",
                            "sharp":  "^0.34.5",
                            "vite":  "^5.0.0"
                        },
    "build":  {
                  "appId":  "nl.bulters.newton",
                  "productName":  "NewTon+",
                  "win":  {
                              "target":  "nsis",
                              "icon":  "build/icon.ico"
                          },
                  "fileAssociations":  [

                                       ],
                  "nsis":  {
                               "perMachine":  false,
                               "oneClick":  false,
                               "shortcutName":  "NewTon+ Metaalrecycling",
                               "createDesktopShortcut":  true,
                               "installerLanguages":  [
                                                          "nl_NL",
                                                          "en_US"
                                                      ],
                               "createStartMenuShortcut":  true,
                               "deleteAppDataOnUninstall":  true,
                               "allowToChangeInstallationDirectory":  true
                           },
                  "publish":  {
                                  "private":  true,
                                  "provider":  "github",
                                  "releaseType":  "release",
                                  "owner":  "michielvgvg",
                                  "repo":  "newton-plus"
                              },
                  "files":  [
                                "dist/**/*",
                                "electron.cjs",
                                "package.json",
                                "build/splash.html",
                                "build/icon-512.png",
                                "build/icon-ico.png"
                            ],
                  "extraResources":  [
                                         {
                                             "to":  "splash.html",
                                             "from":  "build/splash.html"
                                         },
                                         {
                                             "to":  "icon-512.png",
                                             "from":  "build/icon-512.png"
                                         }
                                     ]
              },
    "repository":  {
                       "type":  "git",
                       "url":  "git+https://github.com/michielvgvg/newton-plus.git"
                   }
}