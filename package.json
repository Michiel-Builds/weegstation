{
  "name": "weegstation-app",
  "version": "3.1.10",
  "description": "WeegStation - professioneel weeg- en voorraadsysteem voor metaalrecycling",
  "author": "Michiel Bulters",
  "main": "electron.cjs",
  "scripts": {
    "dev": "vite",
    "server": "node server/weegserver.cjs",
    "build:frontend": "vite build",
    "build:installer": "node convert-icon.mjs && electron-builder --win --publish never",
    "build:win": "npm run build:frontend && npm run build:installer",
    "verify-release": "node scripts/verify-release.mjs",
    "verify-release:local": "node scripts/verify-release.mjs --local",
    "release": "node scripts/release.mjs",
    "publish-release": "node scripts/release.mjs",
    "pak-weegserver": "node scripts/pak-weegserver.mjs",
    "electron:dev": "electron ."
  },
  "dependencies": {
    "@fontsource/dm-sans": "^5.0.0",
    "@fontsource/jetbrains-mono": "^5.0.0",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "serialport": "^12.0.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "canvas": "^3.2.3",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "pdfjs-dist": "^6.0.227",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "nl.weegstation.app",
    "productName": "WeegStation",
    "copyright": "Copyright © 2026 WeegStation",
    "directories": {
      "output": "release/electron-dist"
    },
    "asarUnpack": [
      "dist/**/*",
      "preload.js",
      "electron.cjs"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "signAndEditExecutable": false
    },
    "fileAssociations": [],
    "nsis": {
      "perMachine": false,
      "oneClick": false,
      "shortcutName": "WeegStation",
      "createDesktopShortcut": true,
      "installerLanguages": [
        "nl_NL",
        "en_US"
      ],
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": true,
      "allowToChangeInstallationDirectory": false,
      "include": "build/installer.nsh"
    },
    "publish": {
      "provider": "github",
      "releaseType": "release",
      "owner": "Michiel-Builds",
      "repo": "weegstation"
    },
    "files": [
      "dist/**/*",
      "electron.cjs",
      "preload.js",
      "package.json",
      "server/lma/**/*",
      "build/splash.html",
      "build/icon-512.png",
      "build/icon.ico"
    ],
    "extraResources": [
      {
        "to": "splash.html",
        "from": "build/splash.html"
      },
      {
        "to": "icon-512.png",
        "from": "build/icon-512.png"
      },
      {
        "to": "icon.ico",
        "from": "build/icon.ico"
      },
      {
        "to": "preload.js",
        "from": "preload.js"
      },
      {
        "to": "app-dist",
        "from": "dist"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Michiel-Builds/weegstation.git"
  }
}
