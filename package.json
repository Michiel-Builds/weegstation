{
  "name": "bulters-newton-app",
  "version": "1.1.2",
  "description": "NewTon+ Metaalrecycling Bulters - voorraad- en weegsysteem voor metaalhandel",
  "author": "Michiel Bulters",
  "main": "electron.cjs",
  "scripts": {
    "dev": "vite",
    "server": "node server/weegserver.cjs",
    "build": "vite build",
    "dist": "electron-builder",
    "electron:dev": "electron ."
  },
  "dependencies": {
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "serialport": "^12.0.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "nl.bulters.newton",
    "productName": "NewTon+",
    "copyright": "Copyright © 2026 Bulters Metaalrecycling",
    "asarUnpack": [
      "dist/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "signAndEditExecutable": false
    },
    "fileAssociations": [],
    "nsis": {
      "perMachine": false,
      "oneClick": false,
      "shortcutName": "NewTon+ Metaalrecycling",
      "createDesktopShortcut": true,
      "installerLanguages": [
        "nl_NL",
        "en_US"
      ],
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": true,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh"
    },
    "publish": {
      "private": true,
      "provider": "github",
      "releaseType": "release",
      "owner": "Michiel-Builds",
      "repo": "newton-plus"
    },
    "files": [
      "dist/**/*",
      "electron.cjs",
      "preload.js",
      "package.json",
      "build/splash.html",
      "build/icon-512.png"
    ],
    "extraResources": [
      {
        "to": "splash.html",
        "from": "build/splash.html"
      },
      {
        "to": "icon-512.png",
        "from": "build/icon-512.png"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Michiel-Builds/newton-plus.git"
  }
}
