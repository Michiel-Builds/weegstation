# Kopieer dit bestand naar .env en vul de sleutel in.
# Zelfde sleutel als in WeegStation op de kantoor-PC (dashboard / eerste setup).

WEEGSERVER_KEY=

# Optioneel — COM-poort weegbrug (standaard COM5):
# WEEGBRUG_COM=COM5

# Optioneel — seriele instellingen Bilanciai (standaard 4800 7E1):
# WEEGBRUG_BAUD=4800
# WEEGBRUG_DATA_BITS=7
# WEEGBRUG_STOP_BITS=1
# WEEGBRUG_PARITY=even

# Optioneel — tweede weegschaal loods (leeg laten als niet gebruikt):
# LOODS_COM=COM2

# Optioneel — alleen deze IP's mogen verbinden (kantoor-PC):
# WEEGSERVER_ALLOWED_IPS=192.168.1.10
